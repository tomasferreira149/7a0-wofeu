{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    
    /* Configurações estritas para evitar bugs no simulador */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    
    /* Permite importar bibliotecas antigas sem stress */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}